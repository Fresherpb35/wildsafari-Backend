generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Booking {
  id         String        @id @default(cuid())
  name       String
  email      String
  phone      String?
  safariDate DateTime
  safariType SafariType    @default(GYPSY)
  safariZone String
  safariTime SafariTime    @default(MORNING)
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([email])
  @@index([safariDate])
  @@index([status])
  @@map("bookings")
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    ContactStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@map("contacts")
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@index([email])
  @@map("newsletters")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // Use Markdown or HTML
  excerpt     String?
  imageUrl    String?
  category  String   @default("Wildlife")
tag       String?
readTime  String   @default("6 min read")
color     String   @default("#2d7a4f")
imageEmoji String?  // e.g. "🐯"
  author      String   @default("Admin")
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}

model Hotel {
  id        String   @id @default(cuid())
  name      String
  img       String
  tag       String?
  desc      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hotels")
}

enum SafariType {
  GYPSY
  CANTER
}

enum SafariTime {
  MORNING
  EVENING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
}
