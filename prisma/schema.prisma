generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id         String        @id @default(cuid())
  name       String
  email      String
  phone      String?
  safariDate DateTime
  safariType SafariType    @default(GYPSY)
  safariZone String
  safariTime SafariTime    @default(MORNING)
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([email])
  @@index([safariDate])
  @@index([status])
  @@map("bookings")
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    ContactStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@map("contacts")
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@index([email])
  @@map("newsletters")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

enum SafariType {
  GYPSY
  CANTER
}

enum SafariTime {
  MORNING
  EVENING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
}
